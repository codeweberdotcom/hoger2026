    "opt-gulp-sass-variation": "\/\/--------------------------------------------------------------\r\n\/\/ User Variables — hoger\r\n\/\/ Child тема: codeweber\r\n\/\/ Извлечено из: https:\/\/hoger.pro\/\r\n\/\/ Дата: 2026-03-25\r\n\/\/--------------------------------------------------------------\r\n\/\/ Порядок импорта: _theme-colors → _user-variables → _variables\r\n\/\/\r\n\/\/ ВАЖНО: $primary и $white недоступны в этом файле!\r\n\/\/         Используй $blue вместо $primary, #ffffff вместо $white.\r\n\/\/--------------------------------------------------------------\r\n\r\n\/\/ ── Основные цвета ──\r\n$blue:  #9c886f;   \/\/ Primary → тёплый тауп (было: #3f78e0)\r\n$navy:  #1e2228;   \/\/ Dark sections (было: #343f52)\r\n\r\n$body-color:     #000000;   \/\/ (было: зависит от $navy)\r\n$headings-color: #000000;\r\n$dark:           #1e2228;   \/\/ (было: $navy)\r\n\r\n\/\/ Глобальное скругление — умеренное (pill только для кнопок и инпутов)\r\n$border-radius: 0.25rem;    \/\/ 4px (было: 0.4rem)\r\n\r\n\/\/ ── Типографика ──\r\n$font-family-sans-serif: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Arial, sans-serif;  \/\/ (было: Manrope)\r\n$font-size-root:     16px;   \/\/ (было: 20px) — соответствует MUI htmlFontSize\r\n$font-size-base:     1rem;   \/\/ 16px (было: 0.8rem)\r\n$font-weight-normal: 400;    \/\/ (было: 500)\r\n$line-height-base:   1.6;    \/\/ (было: 1.7)\r\n\r\n\/\/ Заголовки — MUI-совместимая шкала при root 16px\r\n$h1-font-size: 2.5rem;    \/\/ 40px  (сайт: 42px)\r\n$h2-font-size: 2.25rem;   \/\/ 36px  (сайт: 36px ✓)\r\n$h3-font-size: 1.75rem;   \/\/ 28px\r\n$h4-font-size: 1.375rem;  \/\/ 22px  (сайт: 20px)\r\n$h5-font-size: 1.125rem;  \/\/ 18px\r\n$h6-font-size: 1rem;      \/\/ 16px\r\n\r\n\/\/ ── Кнопки ──\r\n$btn-border-width:  2px;\r\n$btn-font-weight:   400;       \/\/ (было: 700) — как на hoger.pro\r\n$btn-border-radius: 50rem;     \/\/ pill! (было: 0.4rem)\r\n\r\n\/\/ Default = hoger.pro .btn-lg при root 20px → конвертировано на наш root 16px\r\n$btn-padding-y:  0.5rem;    \/\/ 8px  (было: 0.5rem)\r\n$btn-padding-x:  1.75rem;   \/\/ 28px (было: 1.2rem)\r\n$btn-font-size:  1rem;      \/\/ 16px (было: 0.8rem)\r\n\r\n\/\/ XS\r\n$btn-padding-y-xs:  0.25rem;\r\n$btn-padding-x-xs:  1.0rem;\r\n$btn-font-size-xs:  0.75rem;\r\n\r\n\/\/ SM\r\n$btn-padding-y-sm:  0.375rem;\r\n$btn-padding-x-sm:  1.25rem;\r\n$btn-font-size-sm:  0.875rem;\r\n\r\n\/\/ MD = Default\r\n$btn-padding-y-md:     $btn-padding-y;\r\n$btn-padding-x-md:     $btn-padding-x;\r\n$btn-font-size-md:     $btn-font-size;\r\n$btn-border-radius-md: $btn-border-radius; \/\/ 50rem pill (было: $border-radius = 0.25rem)\r\n$btn-font-weight-md:   $btn-font-weight;   \/\/ 400 (было: $font-weight-bold = 700)\r\n\r\n\/\/ LG\r\n$btn-padding-y-lg:  0.65rem;\r\n$btn-padding-x-lg:  2.0rem;\r\n$btn-font-size-lg:  1.125rem;\r\n\r\n\/\/ ELG\r\n$btn-padding-y-elg:  0.8rem;\r\n$btn-padding-x-elg:  2.25rem;\r\n$btn-font-size-elg:  1.25rem;\r\n\r\n\/\/ ── Формы ──\r\n$input-font-size:          1rem;     \/\/ 16px (было: 0.75rem)\r\n$input-border-radius:      50rem;    \/\/ pill (как на образце)\r\n$input-border-color:       #9c886f;  \/\/ (было: rgba($shadow-border, 0.07))\r\n$input-padding-y:          0.938rem; \/\/ 15px (было: 0.6rem)\r\n$input-padding-x:          1.25rem;  \/\/ 20px (было: 1rem)\r\n$input-focus-border-color: #9c886f;\r\n$input-focus-box-shadow:   none;\r\n\r\n\/\/ ── Навигация (горизонтальное меню) ──\r\n$nav-link-font-size:      1.125rem; \/\/ 18px (было: 0.8rem)\r\n$nav-link-font-weight:    600;      \/\/ (было: $font-weight-bold \/ 700)\r\n$nav-link-text-transform: none;\r\n\r\n\/\/ ── Breadcrumb ──\r\n$breadcrumb-divider-color: #d2d2d7;\r\n\r\n\/\/--------------------------------------------------------------\r\n\/\/ CSS overrides\r\n\/\/--------------------------------------------------------------\r\n\r\n\/\/ Uppercase + letter-spacing для кнопок\r\n.btn {\r\n    text-transform: uppercase;\r\n    letter-spacing: 0.05em;\r\n}\r\n\r\n\/\/--------------------------------------------------------------\r\n\/\/ Импорт шрифтов\r\n\/\/--------------------------------------------------------------\r\n\r\n\/\/START IMPORT FONTS\r\n@import \"fonts\/Inter\";\r\n\/\/END IMPORT FONTS",
    "opt-font-variation": "\/\/ Font Import\r\n\r\n@font-face {\r\n  font-family: 'Inter';\r\n  src: url('..\/fonts\/Inter\/Inter_18pt-Light.woff2') format('woff2'),\r\n    url('..\/fonts\/Inter\/Inter_18pt-Light.woff') format('woff');\r\n  font-weight: 300;\r\n  font-style: normal;\r\n  font-display: swap;\r\n}\r\n@font-face {\r\n  font-family: 'Inter';\r\n  src: url('..\/fonts\/Inter\/Inter_18pt-Medium.woff2') format('woff2'),\r\n    url('..\/fonts\/Inter\/Inter_18pt-Medium.woff') format('woff');\r\n  font-weight: 500;\r\n  font-style: normal;\r\n  font-display: swap;\r\n}\r\n@font-face {\r\n  font-family: 'Inter';\r\n  src: url('..\/fonts\/Inter\/Inter_18pt-Regular.woff2') format('woff2'),\r\n    url('..\/fonts\/Inter\/Inter_18pt-Regular.woff') format('woff');\r\n  font-weight: 400;\r\n  font-style: normal;\r\n  font-display: swap;\r\n}\r\n\r\n\r\n\/\/ Bootstrap Configuration\r\n@import \"..\/..\/..\/..\/..\/codeweber\/node_modules\/bootstrap\/scss\/mixins\";\r\n\r\n\/\/ Font Variables\r\n$font-family-base: \"Inter\", sans-serif;\r\n$font-family-secondary: \"Inter\", sans-serif;\r\n$font-size-base: 0.85rem;\r\n\r\n\/\/ Font Specific Settings\r\n* {\r\n  word-spacing: normal !important;\r\n}\r\nbody {\r\n  font-family: $font-family-base;\r\n  font-size: $font-size-base;\r\n}\r\n.nav-link,\r\n.dropdown-item,\r\n.btn {\r\n  letter-spacing: normal;\r\n}\r\n.btn,\r\n.navbar .btn-sm,\r\n.nav-link,\r\n.nav-link p,\r\n.lg-sub-html p {\r\n  @include font-size($font-size-base);\r\n}\r\n.dropdown-menu {\r\n  @include font-size($font-size-base - 0.05);\r\n}\r\n.share-dropdown .dropdown-menu .dropdown-item,\r\n.btn-sm,\r\n.btn-group-sm>.btn,\r\n.post-meta {\r\n  @include font-size($font-size-base - 0.1);\r\n}\r\n.meta,\r\n.post-category,\r\n.filter,\r\n.filter ul li a {\r\n  @include font-size($font-size-base - 0.15);\r\n}\r\n.post-header .post-meta {\r\n  @include font-size($font-size-base);\r\n}\r\n.nav-tabs .nav-link,\r\n.accordion-wrapper .card-header button,\r\n.collapse-link {\r\n  @include font-size($font-size-base + 0.05);\r\n}\r\nblockquote {\r\n  @include font-size($font-size-base + 0.05);\r\n}\r\n.blockquote-footer {\r\n  @include font-size($font-size-base - 0.2);\r\n}\r\n.blockquote-details p {\r\n  @include font-size($font-size-base);\r\n}\r\n.counter-wrapper {\r\n  p {\r\n    @include font-size($font-size-base);\r\n  }\r\n  .counter {\r\n    @include font-size(2.05rem);\r\n    &.counter-lg {\r\n      @include font-size(2.25rem)\r\n    }\r\n  }\r\n}\r\n.icon-list.bullet-bg i {\r\n  top: 0.25rem;\r\n}\r\n.accordion-wrapper .card-header button:before {\r\n  margin-top: -0.2rem;\r\n}\r\n.form-floating > label {\r\n  padding-top: 0.65rem;\r\n}\r\n.h1, h1 {\r\n  @include font-size(1.5rem);\r\n}\r\n.h2, h2 {\r\n  @include font-size(1.35rem);\r\n}\r\n.h3, h3 {\r\n  @include font-size(1.15rem);\r\n}\r\n.h4, h4 {\r\n  @include font-size(1rem);\r\n}\r\n.h5, h5 {\r\n  @include font-size(0.95rem);\r\n}\r\n.h6, h6 {\r\n  @include font-size(0.9rem);\r\n}\r\n.fs-sm {\r\n  @include font-size(0.75rem !important);\r\n}\r\n.fs-lg {\r\n  @include font-size(1.05rem !important);\r\n}\r\n.lead {\r\n  @include font-size(0.95rem);\r\n  line-height: 1.6;\r\n}\r\n.lead.fs-lg {\r\n  @include font-size(1.1rem !important);\r\n  line-height: 1.55;\r\n}\r\n.display-1 {\r\n  @include font-size(2.5rem);\r\n  font-family: $font-family-secondary;\r\n  line-height: 1.15;\r\n}\r\n.display-2 {\r\n  @include font-size(2.3rem);\r\n  font-family: $font-family-secondary;\r\n  line-height: 1.2;\r\n}\r\n.display-3 {\r\n  @include font-size(2.1rem);\r\n  font-family: $font-family-secondary;\r\n  line-height: 1.2;\r\n}\r\n.display-4 {\r\n  @include font-size(1.9rem);\r\n  font-family: $font-family-secondary;\r\n  line-height: 1.25;\r\n}\r\n.display-5 {\r\n  @include font-size(1.7rem);\r\n  font-family: $font-family-secondary;\r\n  line-height: 1.25;\r\n}\r\n.display-6 {\r\n  @include font-size(1.5rem);\r\n  font-family: $font-family-secondary;\r\n  line-height: 1.3;\r\n}",
    "redux-backup": 1
}